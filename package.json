{
  "name": "music-player-mass",
  "version": "1.0.0",
  "description": "A premium local MP3 player with synced lyrics.",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
  "appId": "com.promediaplayer.app",

  "productName": "Mass Music Player",

  "directories": {
    "output": "dist"
  },

  "files": [
    "**/*",
    "!dist/**/*",
    "!node_modules/.cache/**/*"
  ],

  "asar": true,

  "mac": {
    "category": "public.app-category.music",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      }
    ],
    "artifactName": "${productName}-${version}-mac.${ext}",
    "icon": "icon.icns",
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },

  "dmg": {
    "sign": false
  },

  "win": {
    "target": "nsis",
    "icon": "icon.ico"
  },

  "fileAssociations": [
    {
      "ext": "mp3",
      "name": "MP3 Audio"
    }
  ]
}
    "fileAssociations": [
      {
        "ext": "mp3",
        "name": "MP3 Audio"
      }
    ]
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@xenova/transformers": "^2.17.2",
    "ffmpeg-static": "^5.3.0",
    "shelljs": "^0.10.0",
    "whisper-node": "^1.1.1",
    "ytmusic-api": "^5.3.1"
  }
}
