{
  "name": "music-player-mass",
  "version": "1.0.0",
  "description": "A premium local MP3 player with synced lyrics.",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.promediaplayer.app",
    "win": {
      "target": "nsis"
    },
    "fileAssociations": [
      {
        "ext": "mp3",
        "name": "MP3 Audio"
      }
    ]
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ffmpeg-static": "^5.3.0",
    "whisper-node": "^1.1.1"
  }
}
