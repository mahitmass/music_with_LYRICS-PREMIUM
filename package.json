{
  "name": "music-player-mass",
  "version": "1.0.0",
  "description": "A premium local MP3 player with synced lyrics.",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.promediaplayer.app",
    "productName": "Music Player Mass",
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "directories": {
      "buildResources": "."
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "icon": "icon.icns"
    },
    "fileAssociations": [
      {
        "ext": "mp3",
        "name": "MP3 Audio"
      }
    ]
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@xenova/transformers": "^2.17.2",
    "ffmpeg-static": "^5.3.0",
    "shelljs": "^0.10.0",
    "whisper-node": "^1.1.1",
    "ytmusic-api": "^5.3.1"
  }
}
